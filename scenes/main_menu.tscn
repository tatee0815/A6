autowrap_mode = 2

[connection signal="pressed" from="CenterContainer/PanelContainer/VBox/HostButton" to="." method="_on_host_button_pressed"]
[connection signal="pressed" from="CenterContainer/PanelContainer/VBox/JoinButton" to="." method="_on_join_button_pressed"]
