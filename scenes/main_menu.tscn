[node name="IPInput" type="LineEdit" parent="CenterContainer/PanelContainer/VBox"]
custom_minimum_size = Vector2(0, 40)
layout_mode = 2
placeholder_text = "Enter IP (default: 127.0.0.1)"
alignment = 1

[node name="JoinButton" type="Button" parent="CenterContainer/PanelContainer/VBox"]
custom_minimum_size = Vector2(0, 45)
layout_mode = 2
text = "🌐  Join Game"

[node name="Separator2" type="HSeparator" parent="CenterContainer/PanelContainer/VBox"]
layout_mode = 2

[node name="SinglePlayerButton" type="Button" parent="CenterContainer/PanelContainer/VBox"]
custom_minimum_size = Vector2(0, 45)
layout_mode = 2
